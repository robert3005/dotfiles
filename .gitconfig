[color]
	ui = auto
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[user]
	name = Robert Kruszewski
	email = dzobert@gmail.com
[core]
	autocrlf = input
	safecrlf = true
	excludesfile = /home/robert3005/.gitignore_global
[github]
	user = robert3005
	token = 570ee9a2d0e7660e9d80f407ee2b3c35
[alias]
    st = status
    ci = commit
    br = branch
    co = checkout
    df = diff
    dc = diff --cached
    lg = log -p
    lol = log --graph --decorate --pretty=oneline --abbrev-commit
    lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
    ls = ls-files
	pull = pull --rebase

    # Show files ignored by git:
    ign = ls-files -o -i --exclude-standard
