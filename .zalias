alias mp="mpd && mpdscribble; ncmpcpp"
alias on="echo ON >| /sys/kernel/debug/vgaswitcheroo/switch"
alias off="echo OFF >| /sys/kernel/debug/vgaswitcheroo/switch"
alias discrete="echo DDIS >| /sys/kernel/debug/vgaswitcheroo/switch"
alias integrated="echo DIGD >| /sys/kernel/debug/vgaswitcheroo/switch"
alias cards="cat /sys/kernel/debug/vgaswitcheroo/switch"
alias fan="cat /proc/acpi/ibm/fan"
alias g="git"
alias signals="cd ~/Documents/Computing2/signals"
